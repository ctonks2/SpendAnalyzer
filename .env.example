# Spend Analyzer Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit the .env file to version control!

# ======== REQUIRED IN PRODUCTION ========

# Flask Environment
# Options: 'production', 'development', 'testing'
FLASK_ENV=development

# Flask Secret Key
# CRITICAL: Required for session security. Generate with:
# python -c "import secrets; print(secrets.token_hex(32))"
# MUST be different for development, staging, and production
SECRET_KEY=your-secret-key-here-generate-a-random-one

# Database URL
# Development (default): Uses SQLite at spend_data.db without this variable
# Production: REQUIRED. Use PostgreSQL.
# Example: postgresql://user:password@host:5432/spend_analyzer
# Also supports: postgresql+psycopg2://user:password@host:5432/dbname
DATABASE_URL=

# ======== OPTIONAL ========

# Mistral AI API Configuration
# Leave empty to use mock/demo mode
MISTRAL_API_KEY=

# Mistral Agent ID (only used if MISTRAL_API_KEY is set)
MISTRAL_AGENT_ID=

# ======== APPLICATION SETTINGS ========

# Maximum file upload size in bytes (default: 5242880 = 5MB)
# MAX_CONTENT_LENGTH=5242880
