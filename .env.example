# Spend Analyzer Environment Variables
# Copy this file to .env and fill in your values

# Flask Environment
FLASK_ENV=production

# Secret Key (generate a secure random string)
# Run: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-generate-a-random-one

# Database URL (PostgreSQL recommended for production)
# For development: sqlite:///spend_data.db
# For production: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://user:password@host:port/spend_analyzer

# Optional: LLM Configuration
# If using Mistral API:
# MISTRAL_API_KEY=your-key-here

# Optional: Application Settings
# MAX_CONTENT_LENGTH=5242880  (5MB file uploads)
